{
  "name": "codedecay",
  "displayName": "CodeDecay QA — Code Quality & Pre-Commit Checks",
  "description": "Production QA tool: decay risk, bug-prone patterns, AI-style signals, and check-before-commit for your repository.",
  "version": "1.0.0",
  "publisher": "codedecay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/codedecay.git"
  },
  "homepage": "https://github.com/your-username/codedecay#readme",
  "bugs": {
    "url": "https://github.com/your-username/codedecay/issues"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Machine Learning", "Programming Languages"],
  "keywords": ["technical debt", "code analysis", "decay", "maintainability", "code quality", "predictive"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "codedecay.analyzeFile", "title": "CodeDecay: Analyze Current File", "icon": "$(search)" },
      { "command": "codedecay.analyzeProject", "title": "CodeDecay: Analyze Entire Project", "icon": "$(file-directory)" },
      { "command": "codedecay.checkBeforeCommit", "title": "CodeDecay: Check before commit", "icon": "$(checklist)" },
      { "command": "codedecay.showPanel", "title": "CodeDecay: Show Analysis Panel", "icon": "$(graph)" },
      { "command": "codedecay.showAnalytics", "title": "CodeDecay: Show Analytics Dashboard", "icon": "$(dashboard)" },
      { "command": "codedecay.showHighRisk", "title": "CodeDecay: Show High-Risk Files", "icon": "$(warning)" },
      { "command": "codedecay.analyzeGithub", "title": "CodeDecay: Analyze GitHub URL", "icon": "$(link-external)" }
    ],
    "menus": {
      "editor/context": [{ "command": "codedecay.analyzeFile", "group": "codedecay@1" }],
      "explorer/context": [{ "command": "codedecay.analyzeFile", "group": "codedecay@1" }],
      "commandPalette": [
        { "command": "codedecay.analyzeFile" },
        { "command": "codedecay.analyzeProject" },
        { "command": "codedecay.checkBeforeCommit" },
        { "command": "codedecay.showPanel" },
        { "command": "codedecay.showAnalytics" },
        { "command": "codedecay.showHighRisk" },
        { "command": "codedecay.analyzeGithub" }
      ]
    },
    "configuration": {
      "title": "CodeDecay",
      "properties": {
        "codedecay.apiUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the CodeDecay backend API"
        },
        "codedecay.autoAnalyze": {
          "type": "boolean",
          "default": false,
          "description": "Automatically analyze files when opened"
        },
        "codedecay.riskThreshold": {
          "type": "number",
          "default": 60,
          "description": "Decay score threshold for highlighting (0-100)"
        },
        "codedecay.apiSecret": {
          "type": "string",
          "default": "",
          "description": "Bearer token for CodeDecay QA API when API_SECRET_KEY is set on the server (leave empty for local dev)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "axios": "^1.6.2"
  }
}
