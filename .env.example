# --- CodeDecay QA (production) ---
# Copy to .env and adjust. Never commit real secrets.

# development | production
ENV=development

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# Optional: protect API (extension + CI send Authorization: Bearer <token>)
# Generate: openssl rand -hex 32
API_SECRET_KEY=

# CORS: comma-separated origins (required for browser UIs). VS Code extension often does not need CORS.
# Example: https://qa-dashboard.internal.company
CORS_ORIGINS=

# In production, set false so clients never see stack traces in JSON errors
EXPOSE_ERROR_DETAILS=false

# QA limits
MAX_PRE_COMMIT_FILES=200
MAX_FILE_BYTES_FOR_SCAN=2097152
MAX_PATH_LENGTH=4096

# Paths (defaults work for local; Docker uses /app/data)
VECTOR_DB_PATH=./data/vectordb
METRICS_DB_PATH=./data/metrics.db
MODEL_PATH=./data/models

# Optional LLM features
OPENAI_API_KEY=
